<%- include('./partials/header') %>

<div class="max-w-4xl mx-auto px-6 py-12">
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-bold text-gray-800">My Orders</h1>
        <a href="/shop" class="text-red-500 hover:text-red-600 font-semibold flex items-center gap-1">
            <i class="ri-shopping-bag-line"></i> Continue Shopping
        </a>
    </div>

    <% if (success && success.length > 0) { %>
        <div class="mb-6 bg-green-50 border border-green-200 text-green-800 rounded-lg px-4 py-3 flex items-center gap-2">
            <i class="ri-checkbox-circle-line text-green-500 text-xl"></i>
            <span><%= success[0] %></span>
        </div>
    <% } %>

    <% if (orders && orders.length > 0) { %>
        <div class="space-y-6">
            <% orders.slice().reverse().forEach(function(order, index) { %>
                <div class="bg-white rounded-2xl shadow-md overflow-hidden">
                    <!-- Order Header -->
                    <div class="flex flex-wrap items-center justify-between px-6 py-4 bg-gray-50 border-b border-gray-100 gap-3">
                        <div>
                            <p class="text-xs text-gray-400 mb-0.5">Order ID</p>
                            <p class="font-mono text-sm text-gray-700">#<%= order._id.toString().slice(-8).toUpperCase() %></p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-400 mb-0.5">Placed on</p>
                            <p class="text-sm text-gray-700"><%= new Date(order.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-400 mb-0.5">Total</p>
                            <p class="text-sm font-bold text-red-500">₹<%= order.total %></p>
                        </div>
                        <div>
                            <%
                                const statusColors = {
                                    pending: 'bg-yellow-100 text-yellow-700',
                                    processing: 'bg-blue-100 text-blue-700',
                                    shipped: 'bg-purple-100 text-purple-700',
                                    delivered: 'bg-green-100 text-green-700',
                                    cancelled: 'bg-red-100 text-red-700'
                                };
                                const statusIcons = {
                                    pending: 'ri-time-line',
                                    processing: 'ri-loader-4-line',
                                    shipped: 'ri-truck-line',
                                    delivered: 'ri-checkbox-circle-line',
                                    cancelled: 'ri-close-circle-line'
                                };
                            %>
                            <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-sm font-semibold capitalize <%= statusColors[order.status] || 'bg-gray-100 text-gray-700' %>">
                                <i class="<%= statusIcons[order.status] || 'ri-question-line' %>"></i>
                                <%= order.status %>
                            </span>
                        </div>
                    </div>

                    <!-- Order Progress -->
                    <div class="px-6 py-4 border-b border-gray-100">
                        <div class="flex items-center gap-0">
                            <% const steps = ['pending','processing','shipped','delivered']; %>
                            <% const currentIdx = steps.indexOf(order.status); %>
                            <% steps.forEach(function(step, i) { %>
                                <div class="flex items-center flex-1 <%= i === steps.length - 1 ? 'flex-none' : '' %>">
                                    <div class="flex flex-col items-center">
                                        <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold <%= (order.status !== 'cancelled' && i <= currentIdx) ? 'bg-red-500 text-white' : 'bg-gray-200 text-gray-400' %>">
                                            <%= i + 1 %>
                                        </div>
                                        <span class="text-xs mt-1 capitalize text-gray-500 hidden sm:block"><%= step %></span>
                                    </div>
                                    <% if (i < steps.length - 1) { %>
                                        <div class="flex-1 h-1 mx-1 rounded <%= (order.status !== 'cancelled' && i < currentIdx) ? 'bg-red-400' : 'bg-gray-200' %>"></div>
                                    <% } %>
                                </div>
                            <% }) %>
                        </div>
                    </div>

                    <!-- Products in order -->
                    <div class="px-6 py-4 space-y-3">
                        <% order.products.forEach(function(item) { %>
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 rounded-lg bg-red-50 flex items-center justify-center text-xl">🛍️</div>
                                <div class="flex-1">
                                    <p class="font-semibold text-gray-800 text-sm"><%= item.name || 'Product' %></p>
                                    <p class="text-xs text-gray-500">Qty: <%= item.quantity %></p>
                                </div>
                                <p class="font-semibold text-gray-700">₹<%= item.price %></p>
                            </div>
                        <% }) %>
                    </div>

                    <!-- Footer -->
                    <div class="px-6 py-3 bg-gray-50 flex flex-wrap justify-between items-center gap-2 text-sm text-gray-500">
                        <div class="flex flex-col gap-1">
                            <span><i class="ri-map-pin-line"></i> Deliver to: <%= order.address || 'Not specified' %></span>
                            <% if (order.paymentId) { %>
                                <span class="text-xs text-green-600 font-mono">
                                    <i class="ri-shield-check-line"></i> Payment ID: <%= order.paymentId %>
                                </span>
                            <% } %>
                        </div>
                        <% if (order.status === 'delivered') { %>
                            <a href="/shop" class="text-red-500 font-semibold hover:underline">Buy Again</a>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <div class="text-center py-24">
            <div class="text-7xl mb-4">📦</div>
            <h3 class="text-2xl font-semibold text-gray-600 mb-2">No orders yet</h3>
            <p class="text-gray-400 mb-8">Your order history will appear here once you make a purchase.</p>
            <a href="/shop" class="inline-block bg-gradient-to-r from-red-500 to-orange-400 text-white font-bold py-3 px-8 rounded-lg hover:shadow-lg transition-shadow">
                <i class="ri-shopping-bag-line"></i> Start Shopping
            </a>
        </div>
    <% } %>
</div>

<%- include('./partials/footer') %>
