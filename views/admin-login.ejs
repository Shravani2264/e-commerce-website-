<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Silly Lillies — Admin Login</title>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet"/>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-gray-900 flex items-center justify-center">

    <div class="w-full max-w-md px-6">
        <!-- Logo -->
        <div class="text-center mb-8">
            <span class="text-4xl">🛍️</span>
            <h1 class="text-2xl font-bold text-white mt-2">Silly Lillies</h1>
            <p class="text-gray-400 text-sm mt-1">Admin Panel</p>
        </div>

        <div class="bg-white rounded-2xl shadow-2xl p-8">
            <h2 class="text-xl font-bold text-gray-800 mb-6">Sign in to continue</h2>

            <% if (error && error.length > 0) { %>
                <div class="mb-4 bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 text-sm flex items-center gap-2">
                    <i class="ri-error-warning-line text-red-500"></i>
                    <%= error[0] %>
                </div>
            <% } %>

            <form action="/owners/login" method="POST" class="space-y-5">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
                    <div class="relative">
                        <i class="ri-mail-line absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
                        <input type="email" name="email" required
                            placeholder="admin@sillylillies.com"
                            class="w-full pl-10 pr-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm">
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                    <div class="relative">
                        <i class="ri-lock-line absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
                        <input type="password" name="password" required
                            placeholder="••••••••"
                            class="w-full pl-10 pr-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-sm">
                    </div>
                </div>

                <button type="submit"
                    class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2.5 rounded-lg transition flex items-center justify-center gap-2">
                    <i class="ri-login-box-line"></i> Login to Admin Panel
                </button>
            </form>

            <p class="text-center text-xs text-gray-400 mt-6">
                <a href="/" class="hover:text-indigo-500 transition">← Back to store</a>
            </p>
        </div>

        <p class="text-center text-xs text-gray-600 mt-4">
            First time? <a href="/owners/setup" class="text-indigo-400 hover:underline">Create admin account →</a>
        </p>
    </div>

</body>
</html>
