<%- include('./partials/header') %>

<div class="max-w-6xl mx-auto px-6 py-12">
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-bold text-gray-800">My Wishlist
            <% if (wishlist && wishlist.length > 0) { %>
                <span class="ml-2 text-lg font-normal text-gray-400">(<%= wishlist.length %> items)</span>
            <% } %>
        </h1>
    </div>

    <% if (success && success.length > 0) { %>
        <div class="mb-6 bg-green-50 border border-green-200 text-green-800 rounded-lg px-4 py-3 flex items-center gap-2">
            <i class="ri-checkbox-circle-line text-green-500 text-xl"></i>
            <span><%= success[0] %></span>
        </div>
    <% } %>

    <% if (wishlist && wishlist.length > 0) { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
            <% wishlist.forEach(function(item) { %>
                <div class="bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-xl transition-shadow group">
                    <!-- Product Image -->
                    <div class="relative h-52 flex items-center justify-center" style="background: linear-gradient(135deg, <%= item.bgcolor || '#fff0f5' %>, #f3f4f6)">
                        <% if (item.imagePath) { %>
                            <img
                                src="<%= item.imagePath %>"
                                alt="<%= item.name %>"
                                class="h-40 w-40 object-contain group-hover:scale-105 transition-transform duration-300"
                            >
                        <% } else if (item.image) { %>
                            <img
                                src="data:image/jpeg;base64,<%= item.image.toString('base64') %>"
                                alt="<%= item.name %>"
                                class="h-40 w-40 object-contain group-hover:scale-105 transition-transform duration-300"
                            >
                        <% } else { %>
                            <span class="text-6xl group-hover:scale-110 transition-transform duration-300">🛍️</span>
                        <% } %>

                        <!-- Remove from wishlist -->
                        <a href="/users/wishlist/remove/<%= item._id %>"
                           class="absolute top-3 right-3 w-9 h-9 bg-white rounded-full flex items-center justify-center text-red-500 shadow-sm hover:bg-red-500 hover:text-white transition"
                           title="Remove from wishlist">
                            <i class="ri-heart-fill"></i>
                        </a>

                        <% if (item.Discount && item.Discount > 0) { %>
                            <span class="absolute top-3 left-3 bg-green-500 text-white text-xs font-bold px-2 py-1 rounded-full">
                                <%= Math.round((item.Discount / (item.price + item.Discount)) * 100) %>% OFF
                            </span>
                        <% } %>
                    </div>

                    <!-- Product Info -->
                    <div class="p-4">
                        <h3 class="font-semibold text-gray-800 text-base truncate"><%= item.name %></h3>
                        <p class="text-xs text-gray-500 mt-0.5">Silly Lillies Collection</p>

                        <div class="flex items-center gap-2 mt-2">
                            <span class="text-lg font-bold text-red-500">₹<%= item.price %></span>
                            <% if (item.Discount && item.Discount > 0) { %>
                                <span class="text-sm text-gray-400 line-through">₹<%= parseInt(item.price) + parseInt(item.Discount) %></span>
                            <% } %>
                        </div>

                        <div class="mt-4 flex gap-2">
                            <a href="/users/wishlist/move-to-cart/<%= item._id %>"
                               class="flex-1 bg-gradient-to-r from-red-500 to-orange-400 text-white text-sm font-semibold py-2 rounded-lg text-center hover:shadow-md transition-shadow">
                                <i class="ri-shopping-cart-line"></i> Move to Cart
                            </a>
                            <a href="/users/wishlist/remove/<%= item._id %>"
                               class="w-10 h-10 border border-gray-200 rounded-lg flex items-center justify-center text-gray-400 hover:border-red-400 hover:text-red-400 transition"
                               title="Remove">
                                <i class="ri-delete-bin-line"></i>
                            </a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <div class="text-center py-24">
            <div class="text-7xl mb-4">❤️</div>
            <h3 class="text-2xl font-semibold text-gray-600 mb-2">Your wishlist is empty</h3>
            <p class="text-gray-400 mb-8">Save products you love by clicking the heart icon on any product.</p>
            <a href="/shop" class="inline-block bg-gradient-to-r from-red-500 to-orange-400 text-white font-bold py-3 px-8 rounded-lg hover:shadow-lg transition-shadow">
                <i class="ri-shopping-bag-line"></i> Explore Products
            </a>
        </div>
    <% } %>
</div>

<%- include('./partials/footer') %>
