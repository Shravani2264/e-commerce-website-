<%- include('./partials/header') %>

<!-- Flash Messages -->
<% if (success_msg && success_msg.length > 0) { %>
    <div class="fixed top-20 left-1/2 -translate-x-1/2 alert alert-success z-50">
        <div class="flex items-center gap-2">
            <i class="ri-checkbox-circle-line"></i>
            <span><%= success_msg %></span>
        </div>
    </div>
<% } %>

<% if (error_msg && error_msg.length > 0) { %>
    <div class="fixed top-20 left-1/2 -translate-x-1/2 alert alert-error z-50">
        <div class="flex items-center gap-2">
            <i class="ri-error-warning-line"></i>
            <span><%= error_msg %></span>
        </div>
    </div>
<% } %>

<% if (error && error.length > 0) { %>
    <div class="fixed top-20 left-1/2 -translate-x-1/2 alert alert-error z-50">
        <div class="flex items-center gap-2">
            <i class="ri-error-warning-line"></i>
            <span><%= error[0] %></span>
        </div>
    </div>
<% } %>

<!-- Main Content -->
<div class="min-h-screen bg-gradient-to-br from-red-50 via-white to-orange-50">
    <div class="grid grid-cols-1 lg:grid-cols-2 min-h-screen">
        <!-- Left Section - Register -->
        <div class="flex items-center justify-center p-8 lg:p-12">
            <div class="w-full max-w-md">
                <div class="mb-8">
                    <h2 class="text-4xl font-bold mb-2">Create Account</h2>
                    <p class="text-gray-600">Join thousands of shoppers and discover our latest collections</p>
                </div>

                <form autocomplete="off" action="/users/register" method="post" class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Full Name</label>
                        <input 
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-red-500 focus:ring-2 focus:ring-red-200 transition" 
                            type="text" 
                            placeholder="Your full name" 
                            name="fullname"
                            required
                        >
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Email Address</label>
                        <input 
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-red-500 focus:ring-2 focus:ring-red-200 transition" 
                            type="email" 
                            placeholder="your@email.com" 
                            name="email"
                            required
                        >
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Password</label>
                        <input 
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-red-500 focus:ring-2 focus:ring-red-200 transition" 
                            type="password" 
                            placeholder="••••••••" 
                            name="password"
                            required
                        >
                        <p class="text-xs text-gray-500 mt-1">At least 6 characters</p>
                    </div>

                    <button 
                        type="submit"
                        class="w-full btn-primary justify-center mt-6"
                    >
                        <i class="ri-user-add-line"></i> Create Account
                    </button>
                </form>

                <div class="mt-6 text-center">
                    <p class="text-gray-600">Already have an account?
                        <a href="#login-section" onclick="document.getElementById('login-section').scrollIntoView({behavior:'smooth'})"
                           class="text-red-500 font-semibold hover:underline">Sign in →</a>
                    </p>
                </div>

                <div class="mt-8 grid grid-cols-3 gap-3">
                    <div class="text-center">
                        <i class="ri-shield-check-line text-2xl text-green-500 mb-2"></i>
                        <p class="text-xs text-gray-600">Secure</p>
                    </div>
                    <div class="text-center">
                        <i class="ri-mail-check-line text-2xl text-blue-500 mb-2"></i>
                        <p class="text-xs text-gray-600">Verified</p>
                    </div>
                    <div class="text-center">
                        <i class="ri-heart-smile-line text-2xl text-pink-500 mb-2"></i>
                        <p class="text-xs text-gray-600">Safe</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Section - Login -->
        <div id="login-section" class="flex items-center justify-center p-8 lg:p-12 bg-gradient-to-br from-red-500 to-orange-500">
            <div class="w-full max-w-md">
                <div class="mb-8 text-white">
                    <h2 class="text-4xl font-bold mb-2">Welcome Back</h2>
                    <p class="text-red-100">Sign in to access your account and favorite collections</p>
                </div>

                <form autocomplete="off" action="/users/login" method="post" class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-white mb-2">Email Address</label>
                        <input 
                            class="w-full px-4 py-3 border border-red-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-white bg-white/90 transition" 
                            type="email" 
                            placeholder="your@email.com" 
                            name="email"
                            required
                        >
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-white mb-2">Password</label>
                        <input 
                            class="w-full px-4 py-3 border border-red-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-white bg-white/90 transition" 
                            type="password" 
                            placeholder="••••••••" 
                            name="password"
                            required
                        >
                    </div>

                    <div class="flex items-center justify-between">
                        <label class="flex items-center gap-2 text-white text-sm">
                            <input type="checkbox" class="rounded" name="remember">
                            Remember me
                        </label>
                        <button type="button" onclick="alert('Password reset coming soon! Contact support.')"
                            class="text-white text-sm hover:underline bg-transparent border-0 cursor-pointer">Forgot password?</button>
                    </div>

                    <button 
                        type="submit"
                        class="w-full bg-white text-red-500 font-bold py-3 rounded-lg hover:bg-gray-100 transition flex items-center justify-center gap-2 mt-6"
                    >
                        <i class="ri-login-box-line"></i> Sign In
                    </button>
                </form>

                <div class="mt-8 text-center">
                    <p class="text-red-100 text-sm">Don't have an account?
                        <a href="#" onclick="window.scrollTo({top:0,behavior:'smooth'})"
                           class="text-white font-semibold hover:underline">Register here ←</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('./partials/footer') %>
