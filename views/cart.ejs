<%- include('./partials/header') %>

<div class="max-w-7xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-bold mb-8 text-gray-800">Shopping Cart</h1>

    <% if (locals.success_msg && locals.success_msg.length > 0) { %>
        <div class="mb-4 alert alert-success"><i class="ri-checkbox-circle-line"></i> <%= locals.success_msg[0] %></div>
    <% } %>

    <% if (cartItems && cartItems.length > 0) { %>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

            <!-- Cart Items -->
            <div class="lg:col-span-2 space-y-4">
                <% cartItems.forEach(function(item) { %>
                    <div class="bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-lg transition-shadow">
                        <div class="flex gap-4 p-4">

                            <!-- Product image -->
                            <div class="w-32 h-32 flex-shrink-0 flex items-center justify-center rounded-xl"
                                 style="background: linear-gradient(135deg, <%= item.bgcolor || '#fff0f5' %>, #f3f4f6)">
                                <% if (item.imagePath) { %>
                                    <img class="max-h-full max-w-full object-contain" src="<%= item.imagePath %>" alt="<%= item.name %>">
                                <% } else if (item.image) { %>
                                    <img class="max-h-full max-w-full object-contain" src="data:image/jpeg;base64,<%= Buffer.from(item.image).toString('base64') %>" alt="<%= item.name %>">
                                <% } else { %>
                                    <span class="text-5xl">🛍️</span>
                                <% } %>
                            </div>

                            <!-- Details -->
                            <div class="flex-1">
                                <h3 class="text-lg font-semibold text-gray-900"><%= item.name %></h3>
                                <p class="text-sm text-gray-500 mt-0.5">Silly Lillies Collection</p>

                                <!-- Qty controls -->
                                <div class="flex items-center justify-between mt-4">
                                    <div class="flex items-center gap-0 bg-gray-100 rounded-lg overflow-hidden">
                                        <a href="/removefromcart/<%= item._id %>"
                                           class="px-3 py-2 hover:bg-gray-200 transition text-gray-700 font-bold text-lg leading-none">
                                            −
                                        </a>
                                        <span class="px-5 py-2 font-semibold text-gray-800"><%= item.quantity %></span>
                                        <a href="/addtocart/<%= item._id %>"
                                           class="px-3 py-2 hover:bg-gray-200 transition text-gray-700 font-bold text-lg leading-none">
                                            +
                                        </a>
                                    </div>

                                    <div class="text-right">
                                        <p class="text-2xl font-bold text-red-500">₹<%= item.price * item.quantity %></p>
                                        <% if (item.quantity > 1) { %>
                                            <p class="text-xs text-gray-400">₹<%= item.price %> each</p>
                                        <% } %>
                                        <% if (item.Discount && item.Discount > 0) { %>
                                            <p class="text-xs text-green-600 font-semibold">₹<%= item.Discount %>/item saved</p>
                                        <% } %>
                                    </div>
                                </div>
                            </div>

                            <!-- Actions -->
                            <div class="flex flex-col items-end gap-3 ml-2">
                                <a href="/removefromcart/<%= item._id %>"
                                   class="text-sm text-red-400 hover:text-red-600 font-semibold flex items-center gap-1"
                                   title="Remove one">
                                    <i class="ri-delete-bin-line"></i> Remove
                                </a>
                                <a href="/users/wishlist/add/<%= item._id %>"
                                   class="text-sm text-blue-400 hover:text-blue-600 font-semibold flex items-center gap-1">
                                    <i class="ri-heart-line"></i> Wishlist
                                </a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>

            <!-- Order Summary -->
            <div class="lg:col-span-1">
                <div class="bg-white rounded-2xl shadow-md p-6 sticky top-24">
                    <h2 class="text-xl font-bold mb-6 text-gray-800">Order Summary</h2>

                    <%
                    let subtotal = 0;
                    cartItems.forEach(item => { subtotal += item.price * item.quantity; });
                    let discount = 0;
                    cartItems.forEach(item => { if (item.Discount) discount += item.Discount * item.quantity; });
                    let tax = Math.round((subtotal - discount) * 0.18);
                    let shipping = subtotal > 500 ? 0 : 50;
                    let total = subtotal - discount + tax + shipping;
                    %>

                    <div class="space-y-3 mb-6 text-sm">
                        <div class="flex justify-between text-gray-600">
                            <span>Subtotal (<%= cartItems.reduce((s,i)=>s+i.quantity,0) %> items)</span>
                            <span>₹<%= subtotal %></span>
                        </div>
                        <% if (discount > 0) { %>
                            <div class="flex justify-between text-green-600 font-semibold">
                                <span>Discount</span>
                                <span>−₹<%= discount %></span>
                            </div>
                        <% } %>
                        <div class="flex justify-between text-gray-600">
                            <span>GST (18%)</span>
                            <span>₹<%= tax %></span>
                        </div>
                        <div class="flex justify-between text-gray-600">
                            <span>Shipping</span>
                            <span class="<%= shipping === 0 ? 'text-green-600 font-semibold' : '' %>">
                                <%= shipping === 0 ? 'FREE' : '₹' + shipping %>
                            </span>
                        </div>
                        <% if (shipping > 0) { %>
                            <p class="text-xs text-orange-500">Add ₹<%= 500 - subtotal %> more for free delivery</p>
                        <% } %>
                        <div class="border-t-2 border-gray-200 pt-3 flex justify-between text-xl font-bold">
                            <span>Total</span>
                            <span class="text-red-500">₹<%= total %></span>
                        </div>
                    </div>

                    <!-- Hidden form for payment verification (submitted via JS) -->
                    <form id="paymentVerifyForm" action="/payment/verify" method="POST" class="hidden">
                        <input type="hidden" name="razorpay_order_id" id="rzp_order_id">
                        <input type="hidden" name="razorpay_payment_id" id="rzp_payment_id">
                        <input type="hidden" name="razorpay_signature" id="rzp_signature">
                        <input type="hidden" name="address" id="rzp_address">
                    </form>

                    <div class="mb-4">
                        <label class="block text-sm font-medium text-gray-700 mb-1">
                            <i class="ri-map-pin-line text-red-400"></i> Delivery Address
                        </label>
                        <textarea
                            id="deliveryAddress"
                            rows="2"
                            placeholder="Enter your full delivery address..."
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-red-400 resize-none"
                        ><%= user.address || '' %></textarea>
                    </div>

                    <% if (razorpayConfigured) { %>
                        <!-- Live Razorpay payment -->
                        <button onclick="initiatePayment()"
                            class="w-full bg-gradient-to-r from-red-500 to-orange-500 text-white font-bold py-3 rounded-xl hover:shadow-lg transition-shadow flex items-center justify-center gap-2">
                            <i class="ri-secure-payment-line"></i> Pay & Place Order
                        </button>
                    <% } else { %>
                        <!-- Demo mode: no Razorpay keys configured -->
                        <form id="demoForm" action="/payment/demo-checkout" method="POST">
                            <input type="hidden" name="address" id="demoAddress">
                        </form>
                        <button onclick="demoCheckout()"
                            class="w-full bg-gradient-to-r from-red-500 to-orange-500 text-white font-bold py-3 rounded-xl hover:shadow-lg transition-shadow flex items-center justify-center gap-2">
                            <i class="ri-secure-payment-line"></i> Place Order (Demo)
                        </button>
                        <p class="text-center text-xs text-gray-400 mt-2">
                            <i class="ri-information-line"></i>
                            Demo mode — no real payment charged.
                            <a href="https://razorpay.com" target="_blank" class="text-indigo-400 underline">Add Razorpay keys</a> for live payments.
                        </p>
                    <% } %>

                    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
                    <script>
                    function demoCheckout() {
                        const address = document.getElementById('deliveryAddress').value.trim();
                        if (!address) {
                            alert('Please enter your delivery address first.');
                            document.getElementById('deliveryAddress').focus();
                            return;
                        }
                        document.getElementById('demoAddress').value = address;
                        document.getElementById('demoForm').submit();
                    }

                    async function initiatePayment() {
                        const address = document.getElementById('deliveryAddress').value.trim();
                        if (!address) {
                            alert('Please enter your delivery address before paying.');
                            document.getElementById('deliveryAddress').focus();
                            return;
                        }

                        try {
                            const res = await fetch('/payment/create-order', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ address }),
                            });
                            const data = await res.json().catch(() => ({ error: 'Server returned an invalid response' }));
                            if (!res.ok || data.error) { alert(data.error || 'Payment error'); return; }

                            const options = {
                                key: data.keyId,
                                amount: data.amount,
                                currency: data.currency,
                                name: 'Silly Lillies',
                                description: 'Order Payment',
                                image: '/images/1bag.png',
                                order_id: data.orderId,
                                handler: function (response) {
                                    document.getElementById('rzp_order_id').value   = response.razorpay_order_id;
                                    document.getElementById('rzp_payment_id').value = response.razorpay_payment_id;
                                    document.getElementById('rzp_signature').value  = response.razorpay_signature;
                                    document.getElementById('rzp_address').value    = address;
                                    document.getElementById('paymentVerifyForm').submit();
                                },
                                prefill: { name: data.userName, email: data.userEmail },
                                theme: { color: '#ef4444' },
                                modal: { ondismiss: function() {} }
                            };
                            const rzp = new Razorpay(options);
                            rzp.on('payment.failed', function(resp) {
                                alert('Payment failed: ' + resp.error.description);
                            });
                            rzp.open();
                        } catch (err) {
                            alert('Could not initiate payment: ' + err.message);
                        }
                    }
                    </script>

                    <a href="/shop"
                       class="block text-center w-full mt-3 border-2 border-gray-200 text-gray-600 font-semibold py-2.5 rounded-xl hover:bg-gray-50 transition">
                        Continue Shopping
                    </a>

                    <div class="mt-5 space-y-2 text-xs text-gray-500">
                        <div class="flex items-center gap-2"><i class="ri-shield-check-line text-green-500 text-base"></i> Secure checkout</div>
                        <div class="flex items-center gap-2"><i class="ri-truck-line text-blue-500 text-base"></i> Free delivery above ₹500</div>
                        <div class="flex items-center gap-2"><i class="ri-refresh-line text-yellow-500 text-base"></i> 7-day easy returns</div>
                    </div>
                </div>
            </div>
        </div>

    <% } else { %>
        <div class="text-center py-24">
            <div class="text-7xl mb-4">🛒</div>
            <h3 class="text-2xl font-semibold text-gray-600 mb-2">Your cart is empty</h3>
            <p class="text-gray-400 mb-8">Browse our collection and find your perfect bag!</p>
            <a href="/shop"
               class="inline-block bg-gradient-to-r from-red-500 to-orange-500 text-white font-bold py-3 px-8 rounded-xl hover:shadow-lg transition-shadow">
                <i class="ri-shopping-bag-line"></i> Start Shopping
            </a>
        </div>
    <% } %>
</div>

<%- include('./partials/footer') %>
