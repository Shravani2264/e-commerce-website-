<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Product — Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet"/>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen flex">

    <!-- Sidebar -->
    <aside class="w-56 bg-gray-900 text-white flex flex-col min-h-screen fixed left-0 top-0 z-40">
        <div class="px-6 py-5 border-b border-gray-700">
            <span class="text-xl font-bold flex items-center gap-2">🛍️ Silly Lillies</span>
            <p class="text-xs text-gray-400 mt-1">Admin Panel</p>
        </div>
        <nav class="flex-1 px-4 py-4 space-y-1">
            <a href="/owners/admin" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-800 text-gray-300 text-sm transition">
                <i class="ri-dashboard-line"></i> Dashboard
            </a>
            <a href="/owners/admin/products/add" class="flex items-center gap-3 px-3 py-2 rounded-lg bg-indigo-600 text-white text-sm font-medium">
                <i class="ri-add-box-line"></i> Add Product
            </a>
            <hr class="border-gray-700 my-3">
            <a href="/shop" target="_blank" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-800 text-gray-300 text-sm transition">
                <i class="ri-store-line"></i> View Store
            </a>
            <a href="/owners/logout" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-red-900 text-red-400 text-sm transition">
                <i class="ri-logout-box-line"></i> Logout
            </a>
        </nav>
        <div class="px-6 py-4 border-t border-gray-700 text-xs text-gray-500">
            Logged in as <span class="text-gray-300"><%= adminName %></span>
        </div>
    </aside>

    <main class="ml-56 flex-1 p-8">
        <div class="flex items-center gap-3 mb-8">
            <a href="/owners/admin" class="text-gray-400 hover:text-gray-700 transition">
                <i class="ri-arrow-left-line text-lg"></i>
            </a>
            <h1 class="text-2xl font-bold text-gray-800">Add New Product</h1>
        </div>

        <% if (error && error.length > 0) { %>
            <div class="mb-4 bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 text-sm flex items-center gap-2">
                <i class="ri-error-warning-line text-red-500"></i> <%= error[0] %>
            </div>
        <% } %>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Form -->
            <div class="lg:col-span-2">
                <form action="/owners/admin/products/add" method="POST" enctype="multipart/form-data"
                      class="bg-white rounded-xl shadow-sm p-6 space-y-5">

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div class="md:col-span-2">
                            <label class="block text-sm font-medium text-gray-700 mb-1">Product Name *</label>
                            <input type="text" name="name" required placeholder="e.g. Classic Tote Bag"
                                class="w-full border border-gray-300 rounded-lg px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm">
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Price (₹) *</label>
                            <input type="number" name="price" required placeholder="e.g. 599" min="0"
                                class="w-full border border-gray-300 rounded-lg px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm">
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Discount Amount (₹)</label>
                            <input type="number" name="discount" placeholder="e.g. 50" min="0" value="0"
                                class="w-full border border-gray-300 rounded-lg px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm">
                            <p class="text-xs text-gray-400 mt-1">Leave 0 for no discount</p>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Product Image</label>
                        <div class="border-2 border-dashed border-gray-300 rounded-lg p-4 text-center hover:border-indigo-400 transition cursor-pointer"
                             onclick="document.getElementById('imageInput').click()">
                            <i class="ri-image-add-line text-3xl text-gray-300 mb-2"></i>
                            <p class="text-sm text-gray-400">Click to upload image</p>
                            <p class="text-xs text-gray-300 mt-1">PNG, JPG up to 5MB</p>
                            <input type="file" name="image" id="imageInput" accept="image/*" class="hidden"
                                   onchange="previewImage(this)">
                        </div>
                        <img id="imagePreview" class="mt-3 h-32 rounded-lg object-contain hidden border border-gray-200 p-1">
                    </div>

                    <div class="border-t border-gray-100 pt-5">
                        <h3 class="text-sm font-semibold text-gray-700 mb-3">Card Colour Scheme</h3>
                        <div class="grid grid-cols-3 gap-4">
                            <div>
                                <label class="block text-xs text-gray-500 mb-1">Background Color</label>
                                <div class="flex gap-2 items-center">
                                    <input type="color" name="bgcolor" value="#f3f4f6"
                                        class="w-10 h-10 rounded cursor-pointer border border-gray-200 p-0.5">
                                    <input type="text" id="bgcolorText" value="#f3f4f6"
                                        class="flex-1 border border-gray-300 rounded px-2 py-1.5 text-xs font-mono focus:outline-none focus:ring-1 focus:ring-indigo-400"
                                        oninput="document.querySelector('[name=bgcolor]').value=this.value">
                                </div>
                            </div>
                            <div>
                                <label class="block text-xs text-gray-500 mb-1">Panel Color</label>
                                <div class="flex gap-2 items-center">
                                    <input type="color" name="panelcolor" value="#ffffff"
                                        class="w-10 h-10 rounded cursor-pointer border border-gray-200 p-0.5">
                                    <input type="text" id="panelcolorText" value="#ffffff"
                                        class="flex-1 border border-gray-300 rounded px-2 py-1.5 text-xs font-mono focus:outline-none focus:ring-1 focus:ring-indigo-400"
                                        oninput="document.querySelector('[name=panelcolor]').value=this.value">
                                </div>
                            </div>
                            <div>
                                <label class="block text-xs text-gray-500 mb-1">Text Color</label>
                                <div class="flex gap-2 items-center">
                                    <input type="color" name="textcolor" value="#1f2937"
                                        class="w-10 h-10 rounded cursor-pointer border border-gray-200 p-0.5">
                                    <input type="text" id="textcolorText" value="#1f2937"
                                        class="flex-1 border border-gray-300 rounded px-2 py-1.5 text-xs font-mono focus:outline-none focus:ring-1 focus:ring-indigo-400"
                                        oninput="document.querySelector('[name=textcolor]').value=this.value">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="flex gap-3 pt-2">
                        <button type="submit"
                            class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-6 py-2.5 rounded-lg transition flex items-center gap-2 text-sm">
                            <i class="ri-save-line"></i> Create Product
                        </button>
                        <a href="/owners/admin"
                           class="border border-gray-300 text-gray-600 font-semibold px-6 py-2.5 rounded-lg hover:bg-gray-50 transition text-sm">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>

            <!-- Preview Card -->
            <div class="lg:col-span-1">
                <div class="bg-white rounded-xl shadow-sm p-5 sticky top-8">
                    <h3 class="text-sm font-semibold text-gray-700 mb-4">Live Preview</h3>
                    <div id="previewCard" class="rounded-xl overflow-hidden border border-gray-100">
                        <div id="previewImageBox" class="h-44 flex items-center justify-center bg-gray-100">
                            <span class="text-4xl" id="previewEmoji">🛍️</span>
                            <img id="previewCardImage" class="hidden h-full w-full object-contain p-2">
                        </div>
                        <div id="previewPanel" class="p-3 bg-white">
                            <p id="previewName" class="font-semibold text-gray-800 text-sm">Product Name</p>
                            <p id="previewPrice" class="text-red-500 font-bold mt-1">₹0</p>
                        </div>
                    </div>
                    <p class="text-xs text-gray-400 mt-3 text-center">Updates as you fill the form</p>
                </div>
            </div>
        </div>
    </main>

    <script>
        function previewImage(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    const preview = document.getElementById('imagePreview');
                    preview.src = e.target.result;
                    preview.classList.remove('hidden');
                    const cardImg = document.getElementById('previewCardImage');
                    cardImg.src = e.target.result;
                    cardImg.classList.remove('hidden');
                    document.getElementById('previewEmoji').classList.add('hidden');
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        // Sync color pickers with text inputs and preview
        document.querySelectorAll('input[type=color]').forEach(picker => {
            const name = picker.name;
            picker.addEventListener('input', () => {
                document.getElementById(name + 'Text').value = picker.value;
                updatePreview();
            });
        });

        document.querySelector('[name=name]').addEventListener('input', e => {
            document.getElementById('previewName').textContent = e.target.value || 'Product Name';
        });
        document.querySelector('[name=price]').addEventListener('input', e => {
            document.getElementById('previewPrice').textContent = '₹' + (e.target.value || '0');
        });

        function updatePreview() {
            const bg = document.querySelector('[name=bgcolor]').value;
            const panel = document.querySelector('[name=panelcolor]').value;
            const text = document.querySelector('[name=textcolor]').value;
            document.getElementById('previewImageBox').style.background = bg;
            document.getElementById('previewPanel').style.background = panel;
            document.getElementById('previewName').style.color = text;
        }
    </script>
</body>
</html>
