<%- include('./partials/header') %>

<!-- Flash Messages -->
<div class="px-6 pt-4">
    <% if (locals.success_msg && locals.success_msg.length > 0) { %>
        <div class="alert alert-success mb-3">
            <i class="ri-checkbox-circle-line"></i> <%= locals.success_msg[0] %>
        </div>
    <% } %>
    <% if (locals.error_msg && locals.error_msg.length > 0) { %>
        <div class="alert alert-error mb-3">
            <i class="ri-error-warning-line"></i> <%= locals.error_msg[0] %>
        </div>
    <% } %>
</div>

<!-- Hero Banner -->
<div class="px-6 py-2">
    <div class="hero-banner">
        <h2>Shop Trendy Bags & Accessories</h2>
        <p>Curated styles for every occasion, fashion that speaks for you.</p>
    </div>
</div>

<!-- Main Content -->
<div class="px-6 pb-20">
    <div class="flex gap-6">

        <!-- Sidebar Filter Form -->
        <aside class="w-56 flex-shrink-0">
            <form action="/shop" method="GET" id="filterForm" class="sidebar">

                <!-- Preserve search if present -->
                <% if (search) { %>
                    <input type="hidden" name="search" value="<%= search %>">
                <% } %>

                <!-- Sort By -->
                <div class="filter-section">
                    <h3 class="filter-title">Sort By</h3>
                    <select name="sortby" onchange="document.getElementById('filterForm').submit()"
                        class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:border-red-500">
                        <option value="popular"    <%= sortby === 'popular'    ? 'selected' : '' %>>Popular</option>
                        <option value="newest"     <%= sortby === 'newest'     ? 'selected' : '' %>>Newest</option>
                        <option value="price-low"  <%= sortby === 'price-low'  ? 'selected' : '' %>>Price: Low to High</option>
                        <option value="price-high" <%= sortby === 'price-high' ? 'selected' : '' %>>Price: High to Low</option>
                    </select>
                </div>

                <!-- Quick Links (not form fields, just anchor links) -->
                <div class="filter-section">
                    <h3 class="filter-title">Collections</h3>
                    <div class="space-y-2">
                        <a href="/shop" class="filter-item"><i class="ri-shopping-bag-line"></i> All Products</a>
                        <a href="/shop?discount=true" class="filter-item <%= discountFilter === 'true' ? 'text-red-500 font-semibold' : '' %>">
                            <i class="ri-discount-percent-line"></i> On Sale
                        </a>
                        <a href="/shop?sortby=newest" class="filter-item"><i class="ri-star-line"></i> Newest First</a>
                    </div>
                </div>

                <!-- Price Range -->
                <div class="filter-section">
                    <h3 class="filter-title">Price Range</h3>
                    <div class="space-y-2">
                        <label class="filter-item">
                            <input type="radio" name="price" value="0-500"
                                <%= price === '0-500'    ? 'checked' : '' %>
                                onchange="document.getElementById('filterForm').submit()">
                            ₹0 – ₹500
                        </label>
                        <label class="filter-item">
                            <input type="radio" name="price" value="500-1000"
                                <%= price === '500-1000' ? 'checked' : '' %>
                                onchange="document.getElementById('filterForm').submit()">
                            ₹500 – ₹1000
                        </label>
                        <label class="filter-item">
                            <input type="radio" name="price" value="1000+"
                                <%= price === '1000+'    ? 'checked' : '' %>
                                onchange="document.getElementById('filterForm').submit()">
                            ₹1000+
                        </label>
                    </div>
                </div>

                <!-- Clear Filters -->
                <% if (search || sortby !== 'popular' || discountFilter || price) { %>
                    <a href="/shop" class="block text-center text-sm text-red-500 hover:underline mt-2">
                        <i class="ri-close-circle-line"></i> Clear all filters
                    </a>
                <% } %>
            </form>
        </aside>

        <!-- Products Grid -->
        <div class="flex-1">
            <!-- Results count -->
            <p class="text-sm text-gray-500 mb-4">
                <%= products.length %> product<%= products.length !== 1 ? 's' : '' %> found
                <% if (search) { %> for "<strong><%= search %></strong>"<% } %>
            </p>

            <% if (products && products.length > 0) { %>
                <div class="products-grid">
                    <% products.forEach(function(product){ %>
                        <div class="product-card group">
                            <div class="product-image-container" style="background: linear-gradient(135deg, <%= product.bgcolor || '#f3f4f6' %>, #e5e7eb)">
                                <% if (product.Discount && product.Discount > 0) { %>
                                    <div class="product-badge">
                                        <%= product.Discount %>% OFF
                                    </div>
                                <% } %>
                                <% if (product.imagePath) { %>
                                    <img class="product-image" src="<%= product.imagePath %>" alt="<%= product.name %>">
                                <% } else if (product.image) { %>
                                    <img class="product-image" src="data:image/jpeg;base64,<%= product.image.toString('base64') %>" alt="<%= product.name %>">
                                <% } else { %>
                                    <span class="text-5xl">🛍️</span>
                                <% } %>
                            </div>

                            <div class="product-info" style="background-color: <%= product.panelcolor || '#ffffff' %>; color: <%= product.textcolor || '#1f2937' %>">
                                <h3 class="product-name"><%= product.name %></h3>

                                <div class="flex items-baseline gap-2">
                                    <span class="product-price">₹<%= product.price %></span>
                                    <% if (product.Discount && product.Discount > 0) { %>
                                        <span class="text-sm line-through opacity-60">₹<%= parseInt(product.price) + parseInt(product.Discount) %></span>
                                    <% } %>
                                </div>

                                <div class="product-rating">
                                    <span class="rating-stars">★★★★★</span>
                                    <span class="rating-count">(24)</span>
                                </div>

                                <div class="product-footer">
                                    <a href="/addtocart/<%= product._id %>" class="btn-add-to-cart">
                                        <i class="ri-shopping-cart-line"></i> Add to Cart
                                    </a>
                                    <a href="/users/wishlist/add/<%= product._id %>" class="btn-wishlist" title="Add to Wishlist">
                                        <i class="ri-heart-line"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="text-center py-20">
                    <i class="ri-shopping-bag-line text-6xl text-gray-300 mb-4"></i>
                    <h3 class="text-xl font-semibold text-gray-500">No products found</h3>
                    <p class="text-gray-400 mt-2">Try adjusting your filters or search terms</p>
                    <a href="/shop" class="inline-block mt-6 text-red-500 hover:underline font-semibold">Clear filters</a>
                </div>
            <% } %>
        </div>
    </div>
</div>

<%- include('./partials/footer') %>
